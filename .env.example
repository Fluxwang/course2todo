# Azure App Registration
# 1. Go to https://portal.azure.com > App registrations > New registration
# 2. Copy Application (client) ID to CLIENT_ID
# 3. Supported account types: "Accounts in any organizational directory and personal Microsoft accounts"
# 4. Authentication > Enable "Allow public client flows"
# 5. API permissions > Add: Calendars.Read, Tasks.ReadWrite (delegated)
CLIENT_ID=your-client-id-here
TENANT_ID=common

# Outlook calendar that contains your classes
CALENDAR_NAME=课程表

# Microsoft To Do list name for homework
TODO_LIST_NAME=作业

# School start date (YYYY-MM-DD), used to calculate teaching week
SCHOOL_START_DATE=2025-02-17
